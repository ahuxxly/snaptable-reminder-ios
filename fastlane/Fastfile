default_platform(:ios)

platform :ios do
  before_all do
    sh("xcodegen generate")
  end

  desc "Run tests and simulator build"
  lane :verify do
    simulator_id = first_available_iphone_simulator
    sh("xcodebuild test -scheme SnapTableReminder -destination 'platform=iOS Simulator,id=#{simulator_id}'")
    sh("xcodebuild build -scheme SnapTableReminder -destination 'platform=iOS Simulator,id=#{simulator_id}'")
  end

  desc "Create an App Store archive"
  lane :archive do
    build_app(
      scheme: "SnapTableReminder",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "SnapTableReminder.ipa"
    )
  end

  desc "Upload a signed build to TestFlight"
  lane :testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      duration: 1200,
      in_house: false
    )

    archive

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/SnapTableReminder.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  private_lane :first_available_iphone_simulator do
    simulator_id = sh("xcrun simctl list devices available | grep -m 1 -E 'iPhone' | grep -Eo '[0-9A-F-]{36}' | head -n 1").strip
    UI.user_error!("No available iPhone simulator was found.") if simulator_id.empty?
    simulator_id
  end
end
