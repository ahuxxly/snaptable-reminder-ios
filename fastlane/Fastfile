default_platform(:ios)

platform :ios do
  desc "Run tests and simulator build"
  lane :verify do
    sh("bash scripts/mac-verify.sh")
  end

  desc "Create an App Store archive"
  lane :archive do
    sh("xcodegen generate")

    build_app(
      scheme: "SnapTableReminder",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "SnapTableReminder.ipa"
    )
  end

  desc "Upload a signed build to TestFlight"
  lane :testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      duration: 1200,
      in_house: false
    )

    archive

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/SnapTableReminder.ipa",
      skip_waiting_for_build_processing: true
    )
  end

end
