require "shellwords"

default_platform(:ios)

def archive_build_options
  options = {
    scheme: "SnapTableReminder",
    export_method: "app-store",
    clean: true,
    output_directory: "build",
    output_name: "SnapTableReminder.ipa"
  }

  team_id = ENV.fetch("APPLE_DEVELOPER_TEAM_ID", "").strip
  profile_name = ENV.fetch("APPLE_PROVISIONING_PROFILE_SPECIFIER", "").strip
  xcargs = []

  if !team_id.empty?
    xcargs << "DEVELOPMENT_TEAM=#{team_id.shellescape}"
  end

  if !profile_name.empty?
    xcargs << "CODE_SIGN_STYLE=Manual"
    xcargs << "PROVISIONING_PROFILE_SPECIFIER=#{profile_name.shellescape}"
    options[:export_options] = {
      method: "app-store",
      signingStyle: "manual",
      teamID: team_id,
      provisioningProfiles: {
        "com.snaptable.reminder" => profile_name
      }
    }
  end

  options[:xcargs] = xcargs.join(" ") unless xcargs.empty?
  options
end

def app_store_connect_api_key_from_env
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
    key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
    duration: 1200,
    in_house: false
  )
end

def app_review_information_from_env
  notes_path = "fastlane/metadata/review_information/notes.txt"
  notes = File.exist?(notes_path) ? File.read(notes_path).strip : ""

  {
    first_name: ENV.fetch("APP_REVIEW_FIRST_NAME"),
    last_name: ENV.fetch("APP_REVIEW_LAST_NAME"),
    phone_number: ENV.fetch("APP_REVIEW_PHONE"),
    email_address: ENV.fetch("APP_REVIEW_EMAIL"),
    notes: notes
  }
end

platform :ios do
  private_lane :validate_upload_environment do
    sh("bash scripts/mac-validate-upload-env.sh")
  end

  private_lane :validate_review_submission_environment do
    validate_upload_environment
    sh("bash scripts/mac-validate-review-contact-env.sh")
    unless ENV.fetch("CONFIRM_SUBMIT_FOR_REVIEW", "") == "YES"
      UI.user_error!("Set CONFIRM_SUBMIT_FOR_REVIEW=YES to submit the app for App Review.")
    end
  end

  desc "Run tests and simulator build"
  lane :verify do
    sh("bash scripts/mac-verify.sh")
  end

  desc "Create an App Store archive"
  lane :archive do
    sh("xcodegen generate")

    build_app(archive_build_options)
  end

  desc "Upload a signed build to TestFlight"
  lane :testflight do
    validate_upload_environment

    api_key = app_store_connect_api_key_from_env

    archive

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/SnapTableReminder.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload App Store metadata without submitting for review"
  lane :metadata do
    validate_upload_environment

    api_key = app_store_connect_api_key_from_env

    deliver(
      api_key: api_key,
      metadata_path: "fastlane/metadata",
      submit_for_review: false,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      force: false
    )
  end

  desc "Upload App Store screenshots without submitting for review"
  lane :screenshots do
    validate_upload_environment

    api_key = app_store_connect_api_key_from_env

    deliver(
      api_key: api_key,
      screenshots_path: "fastlane/screenshots",
      submit_for_review: false,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: false
    )
  end

  desc "Run App Store review risk checks against App Store Connect metadata"
  lane :review_check do
    validate_upload_environment

    api_key = app_store_connect_api_key_from_env

    precheck(
      api_key: api_key,
      app_identifier: "com.snaptable.reminder",
      include_in_app_purchases: false,
      default_rule_level: :error
    )
  end

  desc "Submit the latest processed build for App Review without automatic release"
  lane :submit_review do
    validate_review_submission_environment

    api_key = app_store_connect_api_key_from_env

    precheck(
      api_key: api_key,
      app_identifier: "com.snaptable.reminder",
      include_in_app_purchases: false,
      default_rule_level: :error
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.snaptable.reminder",
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      run_precheck_before_submit: true,
      precheck_default_rule_level: :error,
      app_review_information: app_review_information_from_env,
      submission_information: {
        export_compliance_uses_encryption: false
      }
    )
  end

end
